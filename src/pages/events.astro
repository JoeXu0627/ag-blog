---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import { events } from "@/data/events";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const titleLocale = locale === "en" ? "en" : "zh-CN";

const sortedEvents = [...events].sort((a, b) => b.date.localeCompare(a.date));
---

<Layout title={`${t.events.title} | ${t.site.title}`} description={t.events.desc}>
  <Header />

  <Breadcrumb />

  <Main pageTitle={t.events.title} pageDesc={t.events.desc}>
    <ul>
      {
        sortedEvents.map(event => (
          <li class="border-border flex flex-col gap-1 border-b py-4 sm:flex-row sm:items-baseline sm:gap-4">
            <time datetime={event.date} class="text-muted-foreground shrink-0 font-mono text-sm">
              {event.date}
            </time>
            <span class="border-border text-muted-foreground w-fit shrink-0 rounded-full border px-2 py-0.5 text-xs">
              {t.events[event.mode]}
            </span>
            <span class="text-lg font-medium">
              {event.link ? (
                <a href={event.link} class="hover:text-accent underline decoration-dashed underline-offset-4">
                  {event.title[titleLocale]}
                </a>
              ) : (
                event.title[titleLocale]
              )}
            </span>
          </li>
        ))
      }
    </ul>
  </Main>

  <Footer />
</Layout>
